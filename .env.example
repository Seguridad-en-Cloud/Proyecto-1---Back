# LiveMenu API – local/dev environment template.
# Copy to `.env` and adjust values. NEVER commit a real `.env`.
# In production these values come from GCP Secret Manager (see docs).

# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=livemenu-api
DEBUG=false
ENABLE_DOCS=true
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────
# Accepts CSV or a JSON array.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost

# ── Database (local) ─────────────────────────────────────────────────────
# Used only when CLOUD_SQL_CONNECTION_NAME is unset.
DB_USER=livemenu
DB_PASSWORD=livemenu
DB_NAME=livemenu
DATABASE_URL=postgresql+asyncpg://livemenu:livemenu@db:5432/livemenu

# ── Database (Cloud SQL — production only) ───────────────────────────────
# CLOUD_SQL_CONNECTION_NAME=my-project:us-central1:livemenu-pg
# DB_USER, DB_NAME above are reused; DB_PASSWORD comes from Secret Manager.

# ── JWT ──────────────────────────────────────────────────────────────────
# Replace with a 32+ byte random value in dev. In production this is read
# from Secret Manager (secret named JWT_SECRET).
JWT_SECRET=change-me-in-production-to-a-strong-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── Security ─────────────────────────────────────────────────────────────
IP_HASH_SALT=change-me-too-to-a-random-salt-value
# Number of trusted proxies/load balancers in front of the API. Cloud Run
# behind a Global LB = 1. Local docker-compose with the nginx in front = 1.
TRUSTED_PROXIES=1

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Object Storage ───────────────────────────────────────────────────────
# `s3` uses the local MinIO container; `gcs` uses Google Cloud Storage.
STORAGE_BACKEND=s3

# S3 / MinIO (used when STORAGE_BACKEND=s3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=livemenu
S3_PUBLIC_URL=http://localhost:9000/livemenu

# GCS (used when STORAGE_BACKEND=gcs)
# GCS_BUCKET=livemenu-images-prod
# GCS_PUBLIC_URL=https://cdn.example.com           # optional CDN/custom domain

# ── GCP integration ──────────────────────────────────────────────────────
# Set this in Cloud Run; presence triggers Secret Manager lookups.
# GCP_PROJECT_ID=my-project

# ── Image Processing ─────────────────────────────────────────────────────
IMAGE_MAX_SIZE_MB=5
IMAGE_WORKER_COUNT=4
